# Local development defaults. Replace these with the production inference server on Vercel.
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=llama3.2:3b
LLM_API_KEY=

# Optional: without a database URL, the app uses its built-in fixtures.
DATABASE_URL=

