#!/bin/sh
set -eu

cd "$(dirname "$0")"

[ "$(git branch --show-current)" = "main" ] || {
  echo "Deploys must run from main."
  exit 1
}

[ -z "$(git status --porcelain)" ] || {
  echo "Commit local changes before deploying."
  exit 1
}

git pull --rebase origin main
npm --prefix app run check
git push origin main

# The Next.js app lives in app/, so the Vercel project's Root Directory must be
# "app". We build locally and ship the prebuilt output so the deploy does not
# depend on remote project settings.
vercel build --prod
vercel deploy --prebuilt --prod --yes

status=$(curl -s -o /dev/null -w '%{http_code}' https://stagegate.vercel.app)
[ "$status" = "401" ] || {
  echo "Unexpected production response: $status (expected 401)."
  exit 1
}

echo "Production is ready: https://stagegate.vercel.app"
